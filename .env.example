# Shared
APP_ENV=development

# Backend
PORT=8080
BASE_URL=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/makeitshort?sslmode=disable
REDIS_URL=redis://localhost:6379/0
REDIS_MACHINE_ID_KEY=makeitshort:node:registration:counter
CACHE_TTL_SECONDS=172800

# Rate limiting
RATE_LIMIT_WRITE_RPS=10
RATE_LIMIT_WRITE_BURST=20
RATE_LIMIT_READ_RPS=100
RATE_LIMIT_READ_BURST=200

# Frontend
VITE_API_BASE_URL=http://localhost:8080
